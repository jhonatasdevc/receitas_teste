{
  "backend": {
    "name": "github",
    "repo": "jhonatasdevc/receitas_teste",
    "branch": "main"
  },
  "media_folder": "public/images/uploads",
  "public_folder": "/images/uploads",
  "collections": [
    {
      "name": "blog",
      "label": "Minhas Receitas",
      "folder": "src/content/blog",
      "create": true,
      "format": "frontmatter",
      "fields": [
        { "label": "Título da Receita", "name": "title", "widget": "string" },
        { 
          "label": "Data de Publicação", 
          "name": "pubDate", 
          "widget": "datetime", 
          "format": "YYYY-MM-DD", 
          "date_format": "YYYY-MM-DD", 
          "time_format": false 
        },
        { "label": "Descrição Curta", "name": "description", "widget": "string", "required": true },
        { "label": "Imagem em Destaque", "name": "image", "widget": "image", "required": false },
        { "label": "Modo de Preparo / Ingredientes", "name": "body", "widget": "markdown" }
      ]
    }
  ]
}
